			{ "path": "plans/bench-plan.md" },
			{ "path": "package.json" },
			{ "path": "app/layout.tsx" },
			{ "path": "app/page.tsx" },
			{ "path": "lib/incidents.ts" },
			{ "path": "docs/architecture.md" }
		],
		"files_include": [
			{ "path": "package.json", "includes": ["next", "react", "zod", "@tanstack/react-query"] },
			{ "path": "app/layout.tsx", "includes": ["metadata", "children"] },
			{ "path": "app/page.tsx", "includes": ["Support Operations Console", "queue", "escalation"] },
			{ "path": "lib/incidents.ts", "includes": ["incidentSchema", "export"] },
			{ "path": "docs/architecture.md", "includes": ["## Route structure", "## Data contracts", "## Implementation phases"] }
		]
	}
}
