{
	"id": "nextjs-support-console",
	"suite": "planning",
	"fixture": "planning-nextjs-support-console",
	"plan_mode": true,
	"plan_file": "plans/bench-plan.md",
	"prompt": "Read {{fixtureRoot}}/SPEC.md, use planning mode to create and approve a plan, execute the requested Next.js scaffold, and finish only after the requested files exist. Reply with DONE only.",
