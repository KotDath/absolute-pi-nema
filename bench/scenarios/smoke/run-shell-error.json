{
	"id": "run-shell-error",
	"suite": "smoke",
	"prompt": "Use bash to run `printf 'fail-shell\\n' | tee fail.txt; exit 7` and answer with the exit code only.",
	"checks": {
		"must_use_tools": ["bash"],
		"must_error_tools": ["bash"],
		"tool_result_text_includes": [
			{
				"tool": "bash",
				"text": "fail-shell"
			},
			{
				"tool": "bash",
				"text": "Exit code: 7"
			}
		],
		"files_exact": [
			{
				"path": "fail.txt",
				"content": "fail-shell\n"
			}
		],
		"final_text_regex": "\\b7\\b"
	}
}
