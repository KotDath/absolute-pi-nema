{
	"id": "run-shell-error",
	"suite": "smoke",
	"prompt": "Use run_shell_command to run `printf 'fail-shell\\n'; exit 7` and answer with the exit code only.",
	"checks": {
		"must_use_tools": ["run_shell_command"],
		"must_error_tools": ["run_shell_command"],
		"tool_result_text_includes": [
			{
				"tool": "run_shell_command",
				"text": "fail-shell"
			},
			{
				"tool": "run_shell_command",
				"text": "Exit code: 7"
			}
		],
		"final_text_regex": "\\b7\\b"
	}
}
