{
	"name": "@pi-nema/absolute-plan",
	"version": "0.1.0",
	"description": "Plan mode extension for pi",
	"type": "module",
	"keywords": ["pi-package"],
	"pi": {
		"extensions": ["./index.ts"]
	},
	"files": ["*.ts", "README.md", "!**/*.test.ts"],
	"scripts": {
		"build": "tsc --project ./tsconfig.json --noEmit",
		"typecheck": "tsc --project ./tsconfig.json --noEmit",
		"test": "vitest run"
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": ">=0.67.0",
		"@mariozechner/pi-ai": ">=0.67.0",
		"@mariozechner/pi-coding-agent": ">=0.67.0",
		"@mariozechner/pi-tui": ">=0.67.0",
		"@sinclair/typebox": "*"
	}
}
