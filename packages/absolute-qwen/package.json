{
	"name": "@pi-nema/absolute-qwen",
	"version": "0.1.0",
	"description": "Qwen provider extension for pi",
	"type": "module",
	"keywords": ["pi-package"],
	"pi": {
		"extensions": ["./index.ts"]
	},
	"files": ["*.ts", "tools/**/*.ts", "lib/**/*.ts", "README.md", "!**/*.test.ts"],
	"scripts": {
		"build": "tsc --project ./tsconfig.json --noEmit",
		"test": "vitest run",
		"typecheck": "tsc --project ./tsconfig.json --noEmit"
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": ">=0.67.0",
		"@mariozechner/pi-ai": ">=0.67.0",
		"@mariozechner/pi-coding-agent": ">=0.67.0",
		"@mariozechner/pi-tui": ">=0.67.0",
		"@sinclair/typebox": "*"
	},
	"dependencies": {
		"glob": "^11.0.0"
	}
}
